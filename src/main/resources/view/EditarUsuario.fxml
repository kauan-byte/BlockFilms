<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="500.0" spacing="15.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.blockfilmes.controller.EditarUsuarioController">
    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>
    <children>
        <Label styleClass="titulo-logo" text="Meu Perfil">
            <font>
                <Font name="System Bold" size="26.0" />
            </font>
        </Label>
        
        <VBox alignment="CENTER" spacing="8.0">
            <children>
                <ImageView fx:id="imgPerfil" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 0);" />
                <Button fx:id="btnAlterarFoto" mnemonicParsing="false" onAction="#handleAlterarFoto" style="-fx-background-color: #333333; -fx-text-fill: white;" text="Alterar Foto de Perfil" />
            </children>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </VBox>

        <VBox maxWidth="350.0" spacing="3.0">
            <children>
                <Label text="Nome Completo" />
                <TextField fx:id="txtNome" prefHeight="35.0" />
            </children>
        </VBox>

        <VBox maxWidth="350.0" spacing="3.0">
            <children>
                <Label text="E-mail de Login" />
                <TextField fx:id="txtEmail" editable="false" prefHeight="35.0" style="-fx-opacity: 0.7;" />
            </children>
        </VBox>

        <Button fx:id="btnSalvar" maxWidth="350.0" mnemonicParsing="false" onAction="#handleSalvarPerfil" prefHeight="40.0" styleClass="button-primary" text="Salvar Alterações" />
        <Button fx:id="btnVoltar" mnemonicParsing="false" onAction="#handleVoltar" styleClass="button-hyperlink" text="Voltar para o Catálogo" />
        
        <Label fx:id="lblMensagem" textFill="#e50914" wrapText="true" />
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>