<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="450.0" spacing="15.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.blockfilmes.controller.CadastroUsuarioController">
    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>
    <children>
        <Label styleClass="titulo-logo" text="Crie sua Conta">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        
        <VBox maxWidth="320.0" spacing="3.0">
            <children>
                <Label text="Nome Completo" />
                <TextField fx:id="txtNomeCompleto" prefHeight="35.0" promptText="Seu nome" />
            </children>
        </VBox>

        <VBox maxWidth="320.0" spacing="3.0">
            <children>
                <Label text="Nome de Usuário" />
                <TextField fx:id="txtUsuario" prefHeight="35.0" promptText="Ex: kauan_filmes" />
            </children>
        </VBox>
        
        <VBox maxWidth="320.0" spacing="3.0">
            <children>
                <Label text="E-mail" />
                <TextField fx:id="txtEmail" prefHeight="35.0" promptText="seu@email.com" />
            </children>
        </VBox>
        
        <VBox maxWidth="320.0" spacing="3.0">
            <children>
                <Label text="Senha" />
                <PasswordField fx:id="txtSenha" prefHeight="35.0" promptText="Crie uma senha" />
            </children>
        </VBox>

        <VBox maxWidth="320.0" spacing="5.0">
            <children>
                <Label text="Foto de Perfil" />
                <Button fx:id="btnSelecionarFoto" maxWidth="320.0" mnemonicParsing="false" onAction="#handleSelecionarFoto" prefHeight="35.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-border-color: #8C8C8C; -fx-border-radius: 4px;" text="Selecionar Imagem..." />
                <Label fx:id="lblNomeFoto" text="Nenhuma foto selecionada" textFill="#8c8c8c">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
            </children>
        </VBox>
        
        <Button fx:id="btnCadastrar" maxWidth="320.0" mnemonicParsing="false" onAction="#handleCadastrar" prefHeight="40.0" styleClass="button-primary" text="Cadastrar" />
        
        <Button fx:id="btnVoltar" mnemonicParsing="false" onAction="#handleVoltar" styleClass="button-hyperlink" text="Já tem conta? Voltar para o Login" />
        
        <Label fx:id="lblMensagem" text="" textFill="#e50914" wrapText="true" />
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>