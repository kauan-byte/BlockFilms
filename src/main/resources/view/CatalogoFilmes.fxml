<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="1000.0" spacing="20.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.blockfilmes.controller.CatalogoFilmesController">
    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>
    <children>
        <HBox alignment="CENTER_LEFT" maxWidth="920.0" prefWidth="920.0">
            <children>
                <Label styleClass="titulo-logo" text="BlockFilmes Catálogo">
                    <font>
                        <Font name="System Bold" size="26.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="15.0">
                    <children>
                        <Button fx:id="btnPerfil" mnemonicParsing="false" onAction="#handleIrParaPerfil" style="-fx-background-color: #454545;" styleClass="button-primary" text="Meu Perfil 👤" />
                    </children>
                </HBox>
            </children>
        </HBox>
        
        <TableView fx:id="tabelaFilmes" maxWidth="920.0" prefHeight="480.0" prefWidth="920.0" style="-fx-background-color: #333333;">
            <columns>
                <TableColumn fx:id="colCapa" prefWidth="100.0" text="Capa" />
                <TableColumn fx:id="colTitulo" prefWidth="180.0" text="Título" />
                <TableColumn fx:id="colCategoria" prefWidth="120.0" text="Categoria" />
                <TableColumn fx:id="colClassificacao" prefWidth="110.0" text="Classificação" />
                <TableColumn fx:id="colSinopse" prefWidth="390.0" text="Sinopse" />
            </columns>
        </TableView>
        
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="btnNovoFilme" mnemonicParsing="false" onAction="#handleIrParaCadastro" prefHeight="40.0" prefWidth="180.0" styleClass="button-primary" text="Cadastrar Novo Filme" />
                <Button fx:id="btnSair" mnemonicParsing="false" onAction="#handleSair" styleClass="button-hyperlink" text="Sair" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
</VBox>