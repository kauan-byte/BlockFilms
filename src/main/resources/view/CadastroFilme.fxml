<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="650.0" prefWidth="500.0" spacing="15.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.blockfilmes.controller.CadastroFilmeController">
    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>
    <children>
        <Label styleClass="titulo-logo" text="Cadastrar Novo Filme">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>
        
        <VBox maxWidth="380.0" spacing="3.0">
            <children>
                <Label text="Título do Filme" />
                <TextField fx:id="txtTitulo" prefHeight="35.0" promptText="Ex: Interestelar" />
            </children>
        </VBox>

        <HBox maxWidth="380.0" spacing="20.0">
            <children>
                <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                    <children>
                        <Label text="Gênero / Categoria" />
                        <ComboBox fx:id="comboCategoria" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Selecione..." />
                    </children>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="3.0">
                    <children>
                        <Label text="Classificação" />
                        <ComboBox fx:id="comboClassificacao" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Selecione..." />
                    </children>
                </VBox>
            </children>
        </HBox>
        
        <VBox maxWidth="380.0" spacing="3.0">
            <children>
                <Label text="Sinopse" />
                <TextArea fx:id="txtSinopse" prefHeight="100.0" promptText="Digite o resumo do filme..." wrapText="true" />
            </children>
        </VBox>

        <VBox maxWidth="380.0" spacing="5.0">
            <children>
                <Label text="Capa do Filme (Imagem)" />
                <Button fx:id="btnSelecionarCapa" maxWidth="380.0" mnemonicParsing="false" onAction="#handleSelecionarCapa" prefHeight="35.0" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-border-color: #8C8C8C; -fx-border-radius: 4px;" text="Selecionar Imagem..." />
                <Label fx:id="lblNomeCapa" text="Nenhuma imagem selecionada" textFill="#8c8c8c">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
            </children>
        </VBox>
        
        <Button fx:id="btnSalvar" maxWidth="380.0" mnemonicParsing="false" onAction="#handleSalvarFilme" prefHeight="40.0" styleClass="button-primary" text="Salvar Filme" />
        
        <Button fx:id="btnSair" mnemonicParsing="false" onAction="#handleSair" styleClass="button-hyperlink" text="Voltar ao Catálogo" />
        
        <Label fx:id="lblMensagem" text="" textFill="#e50914" wrapText="true" />
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>