<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="400.0" spacing="20.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.blockfilmes.controller.LoginController">
    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>
    <children>
        <Label styleClass="titulo-logo" text="BlockFilmes">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
            <VBox.margin>
                <Insets bottom="20.0" />
            </VBox.margin>
        </Label>
        
        <VBox maxWidth="300.0" spacing="5.0">
            <children>
                <Label text="Usuário" />
                <TextField fx:id="txtUsuario" prefHeight="40.0" promptText="Digite seu usuário" />
            </children>
        </VBox>
        
        <VBox maxWidth="300.0" spacing="5.0">
            <children>
                <Label text="Senha" />
                <PasswordField fx:id="txtSenha" prefHeight="40.0" promptText="Digite sua senha" />
            </children>
        </VBox>
        
        <Button fx:id="btnEntrar" maxWidth="300.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" styleClass="button-primary" text="Entrar" />
        
        <Button fx:id="btnCadastrarSe" mnemonicParsing="false" onAction="#handleIrParaCadastro" styleClass="button-hyperlink" text="Novo no BlockFilmes? Cadastre-se aqui." />
        
        <Label fx:id="lblErro" text="" textFill="#e50914" wrapText="true" />
    </children>
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
</VBox>