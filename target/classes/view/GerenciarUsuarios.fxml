<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" spacing="20.0" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #141414; -fx-padding: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.blockfilmes.controller.GerenciarUsuariosController">
   <children>
      <Text fill="#e50914" strokeType="OUTSIDE" strokeWidth="0.0" text="Gerenciamento de Usuários">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Text>
      
      <TableView fx:id="tabelaUsuarios" prefHeight="480.0" prefWidth="940.0" stylesheets="@../styles/style.css">
        <columns>
          <TableColumn fx:id="colNome" prefWidth="250.0" text="Nome" />
          <TableColumn fx:id="colEmail" prefWidth="300.0" text="E-mail" />
          <TableColumn fx:id="colTipo" prefWidth="180.0" text="Tipo de Conta" />
          <TableColumn fx:id="colAcoes" prefWidth="180.0" text="Ações" />
        </columns>
      </TableView>
      
      <Button mnemonicParsing="false" onAction="#handleVoltar" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20;" text="Voltar ao Catálogo" />
   </children>
</VBox>